{
  "dashboard": {
    "title": "Viola XDR — Gateway API SLOs",
    "uid": "viola-gateway-slos",
    "tags": ["viola", "gateway", "slo"],
    "timezone": "utc",
    "refresh": "30s",
    "time": { "from": "now-6h", "to": "now" },
    "panels": [
      {
        "title": "API P99 Latency (SLO: ≤200ms)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"gateway-api\"}[5m])))",
            "legendFormat": "P99"
          },
          {
            "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"gateway-api\"}[5m])))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"gateway-api\"}[5m])))",
            "legendFormat": "P50"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 0.15 },
                { "color": "red", "value": 0.2 }
              ]
            }
          }
        }
      },
      {
        "title": "Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job=\"gateway-api\"}[5m]))",
            "legendFormat": "Total"
          },
          {
            "expr": "sum(rate(http_requests_total{job=\"gateway-api\", status=~\"2..\"}[5m]))",
            "legendFormat": "2xx"
          },
          {
            "expr": "sum(rate(http_requests_total{job=\"gateway-api\", status=~\"4..\"}[5m]))",
            "legendFormat": "4xx"
          },
          {
            "expr": "sum(rate(http_requests_total{job=\"gateway-api\", status=~\"5..\"}[5m]))",
            "legendFormat": "5xx"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps" }
        }
      },
      {
        "title": "5xx Error Rate (SLO: <0.5%)",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "(sum(rate(http_requests_total{job=\"gateway-api\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"gateway-api\"}[5m]))) * 100",
            "legendFormat": "5xx %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 0.25 },
                { "color": "red", "value": 0.5 }
              ]
            },
            "max": 3
          }
        }
      },
      {
        "title": "Auth Failure Rate",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
        "targets": [
          {
            "expr": "(sum(rate(http_requests_total{job=\"gateway-api\", status=\"401\"}[5m])) / sum(rate(http_requests_total{job=\"gateway-api\"}[5m]))) * 100",
            "legendFormat": "401 %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 5 },
                { "color": "red", "value": 10 }
              ]
            },
            "max": 25
          }
        }
      },
      {
        "title": "Latency by Route",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum by (route, le) (rate(http_request_duration_seconds_bucket{job=\"gateway-api\"}[5m])))",
            "legendFormat": "{{ route }}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "title": "Active Connections",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 14 },
        "targets": [
          {
            "expr": "sum(http_active_connections{job=\"gateway-api\"})",
            "legendFormat": "connections"
          }
        ]
      },
      {
        "title": "Request Rate by Route",
        "type": "table",
        "gridPos": { "h": 8, "w": 18, "x": 6, "y": 14 },
        "targets": [
          {
            "expr": "sum by (route, method) (rate(http_requests_total{job=\"gateway-api\"}[5m]))",
            "format": "table",
            "instant": true
          }
        ]
      }
    ]
  }
}
